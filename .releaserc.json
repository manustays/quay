{
	"branches": ["main"],
	"tagFormat": "v${version}",
	"plugins": [
		"@semantic-release/commit-analyzer",
		"@semantic-release/release-notes-generator",
		[
			"@semantic-release/changelog",
			{ "changelogFile": "CHANGELOG.md" }
		],
		[
			"@semantic-release/exec",
			{
				"prepareCmd": "node scripts/set-version.mjs ${nextRelease.version} && bash scripts/release-build.sh && node scripts/make-latest-json.mjs"
			}
		],
		[
			"@semantic-release/github",
			{
				"assets": [
					{ "path": "src-tauri/target/universal-apple-darwin/release/bundle/dmg/*.dmg", "label": "macOS universal (.dmg)" },
					{ "path": "src-tauri/target/universal-apple-darwin/release/bundle/macos/*.app.tar.gz", "label": "macOS updater bundle (.app.tar.gz)" },
					{ "path": "latest.json", "label": "Updater manifest (latest.json)" }
				]
			}
		],
		[
			"@semantic-release/git",
			{
				"assets": ["package.json", "src-tauri/tauri.conf.json", "src-tauri/Cargo.toml", "src-tauri/Cargo.lock", "CHANGELOG.md"],
				"message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
			}
		]
	]
}
