{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Quay",
	"version": "0.5.0",
	"identifier": "am.abhi.quay",
	"description": "Native macOS menubar app to start, stop, and monitor local dev servers, Homebrew services, Docker containers, and CLI tools — with live CPU/memory metrics.",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"withGlobalTauri": true,
		"macOSPrivateApi": true,
		"windows": [
			{
				"label": "main",
				"width": 380,
				"height": 520,
				"decorations": false,
				"resizable": false,
				"transparent": true,
				"alwaysOnTop": true,
				"visible": false,
				"skipTaskbar": true,
				"windowEffects": {
					"effects": ["popover"],
					"state": "active",
					"radius": 12
				}
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
